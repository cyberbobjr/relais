# HORLOGER — Scheduler brick configuration
tick_interval_seconds: 30        # How often the scheduler loop checks for due jobs
catch_up_window_seconds: 120     # Jobs older than this after restart are skipped (not triggered in bulk)
jobs_dir: "config/horloger/jobs" # Relative to RELAIS_HOME; individual job YAML files live here
db_path: "storage/horloger.db"  # Relative to RELAIS_HOME; SQLite execution trace
