# Registry des utilisateurs RELAIS
# Copié dans ~/.relais/config/users.yaml au premier lancement.
# La Sentinelle charge ce fichier pour appliquer les ACL.

users:

  # Compte système interne — utilisé par les briques pour s'identifier
  usr_system:
    display_name: "Système RELAIS"
    role: admin
    channels: ["*"]
    blocked: false
    llm_profile: default
    notes: "Compte interne — ne pas supprimer"

  # Propriétaire principal — accès complet
  usr_admin:
    display_name: "Administrateur"
    role: admin
    channels: ["discord", "telegram", "whatsapp", "rest"]
    blocked: false
    llm_profile: precise
    # Identifiants par canal (optionnels)
    identifiers:
      discord: null
      telegram: null
    notes: "Compte administrateur principal"

  # Exemple d'utilisateur standard — à personnaliser
  usr_exemple:
    display_name: "Utilisateur Exemple"
    role: user
    channels: ["discord"]
    blocked: false
    llm_profile: default
    identifiers:
      discord: null
    notes: "Exemple — remplacer ou supprimer"

# Politique par défaut pour les utilisateurs inconnus
default_policy:
  allow: false
  llm_profile: fast
  max_messages_per_hour: 10
