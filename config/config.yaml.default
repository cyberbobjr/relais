# RELAIS system configuration
# This file is copied to ~/.relais/config/config.yaml on first launch.
# Edit ~/.relais/config/config.yaml — never this file.

# ── Redis ───────────────────────────────────────────────────────────────────
redis:
  # Local Unix socket — faster than TCP for single-machine deployments
  unix_socket: ~/.relais/redis.sock
  # Redis master password (override via environment variable)
  password: "${REDIS_PASSWORD}"

# ── LiteLLM ─────────────────────────────────────────────────────────────────
litellm:
  base_url: "http://127.0.0.1:4000"
  # LiteLLM master key (see config/litellm.yaml)
  api_key: "${LITELLM_MASTER_KEY}"

# ── Logging ──────────────────────────────────────────────────────────────────
logging:
  level: INFO
  # Format: "json" (production) or "text" (development)
  format: text
  # Daily rotation, 30-day retention
  rotation: daily
  retention_days: 30

# ── Default LLM profile ──────────────────────────────────────────────────────
llm:
  default_profile: default

# ── Security ─────────────────────────────────────────────────────────────────
security:
  # Active session TTL (seconds)
  session_ttl: 86400
  # Maximum incoming message size (bytes)
  max_message_size: 8192
  # Policy for users absent from portail.yaml
  # Possible values: deny | guest | pending
  #   deny    — reject the message, no reply sent
  #   guest   — allow with the role defined by guest_role in portail.yaml
  #   pending — reject + publish to relais:admin:pending_users for human review
  unknown_user_policy: "deny"

# ── Paths ────────────────────────────────────────────────────────────────────
paths:
  backup: ~/.relais/backup
  media: ~/.relais/media
  skills: ~/.relais/skills
  logs: ~/.relais/logs

# ── Subagents ────────────────────────────────────────────────────────────────
subagents:
  # Master switch — set false to disable all subagents
  enabled: true
