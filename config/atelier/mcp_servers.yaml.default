# MCP (Model Context Protocol) server definitions for RELAIS Atelier.
# Copy to ~/.relais/config/mcp_servers.yaml and enable the servers you need.
# The Atelier brick loads this file before each LLM call to inject tool configs.
#
# timeout  — seconds to wait for an MCP tool response (default: 10)
# max_tools — maximum number of tool definitions returned per call (default: 20)

timeout: 10
max_tools: 20

mcp_servers:

  # Global servers — available for every LLM profile.
  #
  # Two transports are supported:
  #   type: stdio  — Atelier spawns the server as a subprocess (uses command/args).
  #   type: sse    — Atelier connects to a running HTTP/SSE server (uses url).
  global:
    - name: filesystem
      enabled: true
      type: stdio
      command: npx
      args: ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"]
    - name: web-search
      enabled: false
      type: stdio
      command: npx
      args: ["-y", "@modelcontextprotocol/server-brave-search"]
      env:
        BRAVE_API_KEY: "${BRAVE_API_KEY}"
    # SSE server example (server must be running independently before Atelier starts):
    # - name: calendar
    #   enabled: false
    #   type: sse
    #   url: "http://127.0.0.1:8100"

  # Contextual servers — loaded only when the active LLM profile is listed
  # in their 'profiles' array (or when no profile is specified).
  contextual:
    - name: code-tools
      enabled: true
      type: stdio
      command: npx
      args: ["-y", "@modelcontextprotocol/server-github"]
      profiles: [coder, precise]
      env:
        GITHUB_TOKEN: "${GITHUB_TOKEN}"
    # SSE contextual example:
    # - name: my-sse-server
    #   enabled: false
    #   type: sse
    #   url: "http://127.0.0.1:8200"
    #   profiles: [precise]
