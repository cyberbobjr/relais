# Profils LLM RELAIS
# Chaque profil définit le modèle, les paramètres de génération et la résilience.
# Copié dans ~/.relais/config/profiles.yaml au premier lancement.

profiles:

  # Profil par défaut — bon équilibre vitesse/qualité
  default:
    model: anthropic:claude-haiku-4-5
    temperature: 0.7
    max_tokens: 1024
    base_url: null              # null = endpoint par défaut du provider
    api_key_env: ANTHROPIC_API_KEY
    stream: false
    memory:
      short_term_messages: 20
    fallback_model: null
    resilience:
      retry_attempts: 3
      retry_delays: [2, 5, 15]
      fallback_model: null

  # Profil rapide — réponses courtes, latence minimale
  fast:
    model: anthropic:claude-haiku-4-5
    temperature: 0.5
    max_tokens: 256
    base_url: null
    api_key_env: ANTHROPIC_API_KEY
    stream: false
    memory:
      short_term_messages: 10
    fallback_model: null
    resilience:
      retry_attempts: 2
      retry_delays: [1, 3]
      fallback_model: null

  # Profil précis — raisonnement approfondi, réponses longues
  precise:
    model: anthropic:claude-sonnet-4-5
    temperature: 0.3
    max_tokens: 4096
    base_url: null
    api_key_env: ANTHROPIC_API_KEY
    stream: false
    memory:
      short_term_messages: 30
    fallback_model: haiku-4-5
    resilience:
      retry_attempts: 3
      retry_delays: [2, 5, 15]
      fallback_model: mistral-small-2603

  # Profil codeur — génération et révision de code
  # Exemple avec modèle local (LM Studio / Ollama) :
  #   model: openai:mon-modele-local
  #   base_url: "${LM_STUDIO_URL}"   # export LM_STUDIO_URL=http://192.168.1.x:1234/v1
  #   api_key_env: null
  coder:
    model: anthropic:claude-sonnet-4-5
    temperature: 0.2
    max_tokens: 8192
    base_url: null
    api_key_env: ANTHROPIC_API_KEY
    stream: false
    memory:
      short_term_messages: 20
    fallback_model: mistral-small-2603
    resilience:
      retry_attempts: 3
      retry_delays: [2, 5, 15]
      fallback_model: mistral-small-2603

