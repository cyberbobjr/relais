# RELAIS LLM profiles
# Each profile defines the model, generation parameters, and resilience settings.
# Copied to ~/.relais/config/profiles.yaml on first launch.

profiles:

  # Default profile — good balance between speed and quality
  default:
    model: anthropic:claude-haiku-4-5
    temperature: 0.7
    max_tokens: 1024
    base_url: null              # null = use the provider's default endpoint
    api_key_env: ANTHROPIC_API_KEY
    stream: false
    memory:
      short_term_messages: 20
    fallback_model: null
    resilience:
      retry_attempts: 3
      retry_delays: [2, 5, 15]
      fallback_model: null

  # Fast profile — short responses, minimal latency
  fast:
    model: anthropic:claude-haiku-4-5
    temperature: 0.5
    max_tokens: 256
    base_url: null
    api_key_env: ANTHROPIC_API_KEY
    stream: false
    memory:
      short_term_messages: 10
    fallback_model: null
    resilience:
      retry_attempts: 2
      retry_delays: [1, 3]
      fallback_model: null

  # Precise profile — deep reasoning, long responses
  precise:
    model: anthropic:claude-sonnet-4-5
    temperature: 0.3
    max_tokens: 4096
    base_url: null
    api_key_env: ANTHROPIC_API_KEY
    stream: false
    memory:
      short_term_messages: 30
    fallback_model: haiku-4-5
    resilience:
      retry_attempts: 3
      retry_delays: [2, 5, 15]
      fallback_model: mistral-small-2603

  # Coder profile — code generation and review
  # Example with a local model (LM Studio / Ollama):
  #   model: openai:my-local-model
  #   base_url: "${LM_STUDIO_URL}"   # export LM_STUDIO_URL=http://192.168.1.x:1234/v1
  #   api_key_env: null
  coder:
    model: anthropic:claude-sonnet-4-5
    temperature: 0.2
    max_tokens: 8192
    base_url: null
    api_key_env: ANTHROPIC_API_KEY
    stream: false
    memory:
      short_term_messages: 20
    fallback_model: mistral-small-2603
    resilience:
      retry_attempts: 3
      retry_delays: [2, 5, 15]
      fallback_model: mistral-small-2603
