# RELAIS channel configuration.
#
# Each entry configures one Aiguilleur adapter.
# Copy to ~/.relais/config/aiguilleur.yaml to override defaults.
#
# Fields per channel:
#   enabled     (bool)   — Whether the adapter is started by the Aiguilleur process.
#                          A disabled channel exits cleanly at startup (exit 0).
#   streaming   (bool)   — Whether the channel supports real-time chunk rendering.
#                          Atelier reads this flag to decide whether to publish
#                          incremental chunks on relais:messages:streaming:{channel}:{cid}.
#   type        (str)    — "native" (Python, runs in a thread) or
#                          "external" (subprocess, e.g. Node.js / Java).
#                          Defaults to "native" if omitted.
#   command     (str)    — For type=external: the executable to spawn.
#   args        (list)   — For type=external: command-line arguments.
#   class       (str)    — Optional fully-qualified Python class path to override
#                          the auto-discovery convention
#                          (aiguilleur.channels.{name}.adapter.*Aiguilleur).
#                          Example: mycompany.adapters.custom.CustomAiguilleur
#   max_restarts (int)   — Max automatic restart attempts on crash. Defaults to 5.
#                          After exhaustion the adapter thread dies and a CRITICAL
#                          log is emitted — the Aiguilleur process stays alive for
#                          other channels.
#   profile     (str)    — Optional LLM profile name to apply to all messages from
#                          this channel (overrides config.yaml > llm.default_profile).
#                          The Aiguilleur stamps envelope.metadata["llm_profile"] with
#                          this value. Omit to fall back to the system default profile.
#                          Example: fast, precise, coder
#                          See config/profiles.yaml for available profiles.
#   prompt_path (str)    — Optional relative path (relative to prompts_dir) to the
#                          channel formatting overlay loaded by Atelier.
#                          The Aiguilleur stamps envelope.metadata["channel_prompt_path"]
#                          with this value so Atelier loads it explicitly.
#                          null means no channel overlay is loaded for this channel.
#                          Example: channels/discord_default.md

channels:

  discord:
    enabled: true
    streaming: false
    # profile not set → falls back to config.yaml > llm.default_profile
    # prompt_path: "channels/discord_default.md"   # uncomment to load channel overlay

  telegram:
    enabled: false
    streaming: true
    profile: fast
    # prompt_path: "channels/telegram_default.md"  # uncomment to load channel overlay

  slack:
    enabled: false
    streaming: false
    # prompt_path: "channels/slack_default.md"     # uncomment to load channel overlay

  rest:
    enabled: false
    streaming: true
    type: native
    bind: "127.0.0.1"
    port: 8080
    request_timeout: 300
    cors_origins:
      - "*"
    include_traces: false

  tui:
    enabled: false
    streaming: true

  whatsapp:
    enabled: false          # disabled by default; enable in ~/.relais/config/aiguilleur.yaml
    streaming: false        # baileys-api does not support streaming in MVP
    profile: default
    prompt_path: "channels/whatsapp_default.md"
    max_restarts: 5
