# Behavioural configuration for the Atelier brick.
# Copied to ~/.relais/config/atelier.yaml on first launch.

# ── Real-time display ────────────────────────────────────────────────────────
display:
  # Master switch — false disables all event publishing
  enabled: true
  # When true, only the text after the last tool call is transmitted to the channel.
  # Intermediate narration tokens (before a tool_call) are discarded.
  final_only: true
  # Maximum length of the published detail field (truncated beyond this)
  detail_max_length: 100
  # Events transmitted to the channel (streaming or final block)
  events:
    tool_call: true
    tool_result: true
    subagent_start: true
    thinking: false
