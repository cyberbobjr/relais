# Configuration comportementale du brick Atelier.
# Copié dans ~/.relais/config/atelier.yaml au premier lancement.

# ── Affichage temps réel ─────────────────────────────────────────────────────
display:
  # Interrupteur maître — false désactive toute publication d'événements
  enabled: true
  # Si true, seul le texte après le dernier appel outil est transmis au channel.
  # Les tokens de narration intermédiaires (avant un tool_call) sont ignorés.
  final_only: true
  # Longueur max du détail publié (tronqué au-delà)
  detail_max_length: 100
  # Événements transmis au channel (streaming ou bloc final)
  events:
    tool_call: true
    tool_result: true
    subagent_start: true
    thinking: false
