forgeron:
  # LLM profile for skill creation (precise, heavier model).
  # References a named profile from atelier/profiles.yaml (config cascade).
  llm_profile: "precise"

  # LLM profile for direct SKILL.md editing.
  edit_profile: "precise"

  # Enable direct SKILL.md editing after turns with errors or after
  # edit_call_threshold cumulative calls.
  edit_mode: true

  # Minimum tool errors in a turn to trigger a skill edit.
  edit_min_tool_errors: 1

  # Cooldown for skill edits per skill (seconds).
  # Redis TTL key: relais:skill:edit_cooldown:{skill_name}
  edit_cooldown_seconds: 300

  # Trigger a skill edit after this many cumulative calls,
  # even when there are no errors.
  edit_call_threshold: 10

  # skills_dir: null means resolved from the config cascade
  # (~/.relais/skills/ > /opt/relais/skills/ > ./skills/)
  skills_dir: null

  # --- Automatic skill creation from session archives ---

  # Enable automatic skill creation from recurring session patterns.
  # Forgeron consumes relais:memory:request (forgeron_archive_group) to detect
  # sessions with the same intent_label and create a new SKILL.md.
  creation_mode: true

  # Minimum number of sessions sharing the same intent_label before creating a skill.
  min_sessions_for_creation: 3

  # Minimum interval between two creation attempts for the same intent label (seconds).
  # Redis TTL key: relais:skill:creation_cooldown:{intent_label}
  creation_cooldown_seconds: 86400

  # Number of representative sessions passed to SkillCreator LLM.
  max_sessions_for_labeling: 5

  # Notify the user when Forgeron creates a new skill.
  notify_user_on_creation: true

  # --- Correction pipeline ---

  # Enable the correction pipeline: user feedback triggers skill-designer via force_subagent.
  correction_mode: true

  # Seconds to wait for Souvenir BRPOP response when fetching session history.
  history_read_timeout_seconds: 30
