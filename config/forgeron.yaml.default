forgeron:
  # LLM profile for skill creation and consolidation (precise, heavier model).
  # References a named profile from atelier/profiles.yaml (config cascade).
  llm_profile: "precise"

  # LLM profile for Phase 1 changelog observations and intent labeling (fast, cheap).
  annotation_profile: "fast"

  # Enable S3 Phase 1: extract observations into per-skill CHANGELOG.md
  # after turns with errors or after annotation_call_threshold cumulative calls.
  annotation_mode: true

  # Minimum tool errors in a turn to trigger a changelog observation.
  annotation_min_tool_errors: 1

  # Cooldown for changelog observations per skill (seconds).
  # Redis TTL key: relais:skill:annotation_cooldown:{skill_name}
  annotation_cooldown_seconds: 300

  # Trigger a changelog observation after this many cumulative calls,
  # even when there are no errors.
  annotation_call_threshold: 10

  # skills_dir: null means resolved from the config cascade
  # (~/.relais/skills/ > /opt/relais/skills/ > ./skills/)
  skills_dir: null

  # --- Automatic skill creation from session archives ---

  # Enable automatic skill creation from recurring session patterns.
  # Forgeron consumes relais:memory:request (forgeron_archive_group) to detect
  # sessions with the same intent_label and create a new SKILL.md.
  creation_mode: true

  # Minimum number of sessions sharing the same intent_label before creating a skill.
  min_sessions_for_creation: 3

  # Minimum interval between two creation attempts for the same intent label (seconds).
  # Redis TTL key: relais:skill:creation_cooldown:{intent_label}
  creation_cooldown_seconds: 86400

  # Number of representative sessions passed to SkillCreator LLM.
  max_sessions_for_labeling: 5

  # Notify the user when Forgeron creates a new skill.
  notify_user_on_creation: true

  # --- S3 Phase 2: periodic consolidation ---

  # Consolidate SKILL.md when CHANGELOG.md exceeds this many lines.
  consolidation_line_threshold: 80

  # Minimum interval between two consolidations for the same skill (seconds, default 7 days).
  # Redis TTL key: relais:skill:consolidation_cooldown:{skill_name}
  consolidation_cooldown_seconds: 604800

  # LLM profile for consolidation (heavier model than annotation).
  consolidation_profile: "precise"

  # Notify the user when a skill is consolidated.
  notify_user_on_consolidation: true
