# Profils LLM RELAIS
# Chaque profil définit le modèle, les paramètres de génération et la résilience.
# Copié dans ~/.relais/config/profiles.yaml au premier lancement.

profiles:

  # Profil par défaut — bon équilibre vitesse/qualité
  default:
    model: mistral-small-2603
    temperature: 0.7
    max_tokens: 1024
    stream: false
    memory:
      short_term_messages: 20
    resilience:
      retry_attempts: 3
      retry_delays: [2, 5, 15]
      fallback_model: null

  # Profil rapide — réponses courtes, latence minimale
  fast:
    model: mistral-small-2603
    temperature: 0.5
    max_tokens: 256
    stream: false
    memory:
      short_term_messages: 10
    resilience:
      retry_attempts: 2
      retry_delays: [1, 3]
      fallback_model: null

  # Profil précis — raisonnement approfondi, réponses longues
  precise:
    model: claude-sonnet-4-5
    temperature: 0.3
    max_tokens: 4096
    stream: false
    memory:
      short_term_messages: 30
    resilience:
      retry_attempts: 3
      retry_delays: [2, 5, 15]
      fallback_model: mistral-small-2603

  # Profil codeur — génération et révision de code
  coder:
    model: qwen3-coder-30b
    temperature: 0.2
    max_tokens: 8192
    stream: false
    memory:
      short_term_messages: 20
    resilience:
      retry_attempts: 3
      retry_delays: [2, 5, 15]
      fallback_model: mistral-small-2603
