# RELAIS Environment Variables Template

OPENROUTER_API_KEY=sk-or-xxx

# Messaging Bridges
DISCORD_BOT_TOKEN=xxx
TELEGRAM_BOT_TOKEN=xxx
SLACK_BOT_TOKEN=xoxb-xxx
SLACK_SIGNING_SECRET=xxx

# Redis Main Configuration
# Default project-local path: ./.relais/redis.sock
REDIS_SOCKET_PATH=./.relais/redis.sock
REDIS_PASSWORD=xxx

# Redis Bricks Passwords (ACLs)
REDIS_PASS_AIGUILLEUR=xxx
REDIS_PASS_PORTAIL=xxx
REDIS_PASS_SENTINELLE=xxx
REDIS_PASS_ATELIER=xxx
REDIS_PASS_SOUVENIR=xxx
REDIS_PASS_SCHEDULER=xxx
REDIS_PASS_HERALD=xxx
REDIS_PASS_LEARNER=xxx
REDIS_PASS_ARCHIVISTE=xxx
REDIS_PASS_WARDEN=xxx
REDIS_PASS_INTAKE=xxx
REDIS_PASS_INSPECTOR=xxx
REDIS_PASS_WEAVER=xxx

# LiteLLM Proxy
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_MASTER_KEY=sk-changeme
LITELLM_MODEL=mistral-small-2603

# LLM routing via LiteLLM proxy (required for claude-agent-sdk)
# These tell the Anthropic SDK / claude CLI to route through the local LiteLLM proxy
# instead of hitting api.anthropic.com directly, so any backend can be used.
ANTHROPIC_BASE_URL=http://localhost:4000
ANTHROPIC_API_KEY=litellm-master-key
# Note: some LiteLLM versions prefer ANTHROPIC_AUTH_TOKEN instead of ANTHROPIC_API_KEY
# ANTHROPIC_AUTH_TOKEN=litellm-master-key

# Optional overrides
# RELAIS_HOME=~/.relais
