# RELAIS Environment Variables Template
LOG_LEVEL=INFO

OPENROUTER_API_KEY=sk-or-xxx

# Messaging Bridges
DISCORD_BOT_TOKEN=xxx
TELEGRAM_BOT_TOKEN=xxx
SLACK_BOT_TOKEN=xoxb-xxx
SLACK_SIGNING_SECRET=xxx

# Redis Main Configuration
# Default project-local path: ./.relais/redis.sock
REDIS_SOCKET_PATH=./.relais/redis.sock
REDIS_PASSWORD=xxx

# Redis Bricks Passwords (ACLs)
REDIS_PASS_AIGUILLEUR=xxx
REDIS_PASS_PORTAIL=xxx
REDIS_PASS_SENTINELLE=xxx
REDIS_PASS_ATELIER=xxx
REDIS_PASS_SOUVENIR=xxx
REDIS_PASS_SCHEDULER=xxx
REDIS_PASS_HERALD=xxx
REDIS_PASS_LEARNER=xxx
REDIS_PASS_ARCHIVISTE=xxx
REDIS_PASS_COMMANDANT=xxx
REDIS_PASS_WARDEN=xxx
REDIS_PASS_INTAKE=xxx
REDIS_PASS_INSPECTOR=xxx
REDIS_PASS_WEAVER=xxx

ANTHROPIC_API_KEY=sk-ant-xxx

# Optional overrides
# Répertoire de données RELAIS (config, skills, logs, redis.sock…).
# Par défaut : .relais/ à la racine du projet.
# Pour un déploiement système, pointer vers un chemin absolu :
RELAIS_HOME=./.relais
